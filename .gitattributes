# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Binary files - no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.hdr binary
*.enc binary
*.glb binary
*.ttf binary
*.woff binary
*.woff2 binary
*.eot binary
*.otf binary
